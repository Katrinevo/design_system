{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
      "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/assets/*": [
        "./assets/*"
      ]
    }
  },
  "include": [
  "styled.d.ts",
  "packages/**/*",
  "mobile-demo/**/*",
  ".storybook/**/*",
  "**/*.ts",
  "**/*.tsx",
  ".expo/types/**/*.ts",
  "expo-env.d.ts"
  ]
}
